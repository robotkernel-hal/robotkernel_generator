def is_builtin(dtype):
    return dtype in builtin_dtypes

def decode_name(inname):
    name = inname
    namespaces = []
    if '/' in inname:
        parts = inname.split('/')
        name = parts[-1]
        namespaces = parts[:-1]

    return (name, namespaces)

def yaml_to_cpp_string(data, indent="    "):
    tmp = []
    inputlines = yaml.dump(data, sort_keys=False).split('\n')
    for line in inputlines:
        if line != "":
            line = line.replace('\\', '\\\\').replace('"', '\\"')
            tmp.append(f'{indent}"{line}\\n"')
    return '\n'.join(tmp)

def to_uint16_vector_lambda(indent):
    return f'''
{indent}// Conversion std::vector<uint8_t> → std::vector<uint16_t>
{indent}auto to_uint16_vector = [](const std::vector<uint8_t>& input) -> std::vector<uint16_t> {{
{indent}    std::vector<uint16_t> output;
{indent}    output.reserve(input.size());
{indent}    std::transform(input.begin(), input.end(), std::back_inserter(output),
{indent}                   [](uint8_t b) {{ return static_cast<uint16_t>(b); }});
{indent}    return output;
{indent}}};
'''

def from_uint16_vector_lambda(indent):
    return f'''
{indent}// Umwandlung: std::vector<uint16_t> → std::vector<uint8_t>
{indent}auto from_uint16_vector = [](const std::vector<uint16_t>& input) -> std::vector<uint8_t> {{
{indent}    std::vector<uint8_t> output;
{indent}    output.reserve(input.size());
{indent}
{indent}    std::transform(input.begin(), input.end(), std::back_inserter(output),
{indent}                   [](uint16_t word) {{
{indent}                       return static_cast<uint8_t>(word & 0xFF);  // nur unteres Byte
{indent}                   }});
{indent}
{indent}    return output;
{indent}}};
'''


class entry():
    def __init__(self, name, node):
        self.name = name
        self.type = node["type"]
        self.yaml_type = self.type if self.type != "uint8_t" else "uint16_t"
        self.array = node["array"] if "array" in node else False
        self.size = node["size"] if "size" in node else -1
        self.default = node["default"] if "default" in node else None

class dtype():
    def __init__(self, name, node):
        self.name = name
        self.real_name, self.namespaces = decode_name(self.name)
        self.fields = [ entry(n, e) for n, e in node["fields"].items() ]
        self.node = node

    def create_struct(self):
        fields = "\n".join(f'    {decode_datatype(f, True)};' for f in self.fields)
        namespaces_open = "\n".join(f'namespace {n} {{' for n in self.namespaces)
        namespaces_close= "\n".join(f'}}; // namespace {n}' for n in self.namespaces)

        return f'''
{namespaces_open}

//! datatype definition for {self.real_name}
static const std::string {self.real_name}_datatype_definition =
{yaml_to_cpp_string(self.node)};

//! data type structure for {self.real_name}
typedef struct {{
{fields}
}} {self.real_name};

{namespaces_close}
'''

    def create_yaml_coverters(self):
        need_lambdas = False
        encode_lines = []
        decode_lines = []
        for f in self.fields:
            if f.type == 'uint8_t' and f.array:
                encode_lines.append(f'            node["{f.name}"] = to_uint16_vector(rhs.{f.name});')
                decode_lines.append(f'            rhs.{f.name} = from_uint16_vector(node["{f.name}"].as<std::vector<uint16_t>>();')
                need_lambdas = True
            else:
                encode_lines.append(f'            node["{f.name}"] = static_cast<{decode_datatype(f, yaml_use=True)}>(rhs.{f.name});')
                decode_lines.append(f'            rhs.{f.name} = node["{f.name}"].as<{decode_datatype(f)}>();')

        encode     = "\n".join(encode_lines)
        decode     = "\n".join(decode_lines)
        validation = "\n".join(f'            if (!node["{f.name}"]) {{ return false; }}' for f in self.fields)
        typename   = "::".join(self.namespaces + [self.real_name])

        return f'''
// Definiere die Konvertierung für Test
namespace YAML {{
    template<>
    struct convert<{typename}> {{
        static Node encode(const {typename}& rhs) {{
            Node node;
{to_uint16_vector_lambda("            ") if need_lambdas else ''}
{encode}
            return node;
        }}

        static bool decode(const Node& node, {typename}& rhs) {{
{from_uint16_vector_lambda("            ") if need_lambdas else ''}
{validation}
{decode}
            return true;
        }}
    }};
}}
'''

class pd_base():
    def __init__(self, name, node):
        self.node = node
        self.org_name = name
        self.name, self.namespaces = decode_name(name)
        print("got ", self.name, self.namespaces)
        self.fields = [ entry(n, e) for n, e in node.items() ]

    def create_class(self):
        namespaces_open = "\n".join(f'namespace {n} {{' for n in self.namespaces)
        namespaces_close= "\n".join(f'}}; // namespace {n}' for n in self.namespaces)
        pd_entries = "\n".join(f'    {decode_datatype(f, True)};' for f in self.fields)

        return f'''
{namespaces_open}

//! service definition for {self.name}
static const std::string pd_{self.name}_datatype_name = 
    "{self.org_name}";

//! service definition for {self.name}
static const std::string pd_{self.name}_datatype_definition = 
{yaml_to_cpp_string(self.node)};

//! service response data structure for {self.name}
struct pd_{self.name} __attribute__((__packed__)) {{
{pd_entries}
}};

{namespaces_close}
'''

class svc_base():
    def __init__(self, name, node):
        self.node = node
        self.org_name = name
        self.name, self.namespaces = decode_name(name)
        self.request = [ entry(n, e) for n, e in node["request"].items() ] if "request" in node else []
        self.response = [ entry(n, e) for n, e in node["response"].items() ] if "response" in node else []

    def create_class(self):
        request_entries = "\n".join(f'    {decode_datatype(f, True)};' for f in self.request)
        response_entries = "\n".join(f'    {decode_datatype(f, True)};' for f in self.response)
        namespaces_open = "\n".join(f'namespace {n} {{' for n in self.namespaces)
        namespaces_close= "\n".join(f'}}; // namespace {n}' for n in self.namespaces)
        init_request = []
        init_response = []
        parse_response = []
        need_from_lambda = False
        need_to_lambda = False

        for e in self.request:
            if e.type == 'uint8_t' and e.array:
                if e.size > 0:
                    parse_response.append(f'#error CASE request uint8_t and array not handled in line service_generate')
                else:
                    init_request.append(f'            local_req.{e.name} = from_uint16_vector(::robotkernel::helpers::get_as'
                                        f'<{decode_datatype(e, yaml_use=True)}>(req, \"{e.name}\"));')
                need_from_lambda = True
            else:
                if e.default is not None:
                    init_request.append(f'            local_req.{e.name} = ::robotkernel::helpers::get_as'
                                        f'<{decode_datatype(e)}>(req, "{e.name}",'
                                        f'{decode_default(e.type, e.default)});')
                else:
                    init_request.append(f'            local_req.{e.name} = ::robotkernel::helpers::get_as'
                                        f'<{decode_datatype(e)}>(req, \"{e.name}\");')

        for e in self.response:
            if e.default is not None:
                init_response.append(f'            local_resp.{e.name} = {decode_default(e.type, e.default)};')

        for e in self.response:
            if e.type == 'uint8_t' and e.array:
                if e.size > 0:
                    parse_response.append(f'#error CASE response uint8_t and array not handled in line service_generate')
                else:
                    parse_response.append(f'            resp[\"{e.name}\"] = to_uint16_vector(local_resp.{e.name});')

                need_to_lambda = True
            else:
                parse_response.append(f'            resp[\"{e.name}\"] = static_cast<{decode_datatype(e, yaml_use=True)}>(local_resp.{e.name});')

        init_response = "\n".join(init_response)
        init_request = "\n".join(init_request)
        parse_response = "\n".join(parse_response)
        add_datatypes = []

        for e in self.request + self.response:
            if not is_builtin(e.type):
                t = types[e.type]
                add_datatypes.append(f'            ::robotkernel::add_datatype_definition(\n'
                                     f'                "{t.name}",\n'
                                     f'                {"::".join(t.namespaces + [t.real_name])}_datatype_definition);')
        add_datatypes = "\n".join(add_datatypes)

        return f'''
{namespaces_open}

//! service definition for {self.name}
static const std::string {self.name}_service_definition = 
{yaml_to_cpp_string(self.node)};

//! service request data structure for {self.name}
struct svc_req_{self.name} {{
{request_entries}
}};

//! service response data structure for {self.name}
struct svc_resp_{self.name} {{
{response_entries}
}};

//! base service class for {self.name}
class svc_base_{self.name} {{
    private:
        //! internal service handler, this one is registered to robotkernel
        /*!
         * @param[in]   req     Service request yaml.
         * @param[out]  resp    Service response yaml.
         * @return 0
         */
        int svc_handler_{self.name}(const YAML::Node& req, YAML::Node& resp) {{
            struct svc_req_{self.name} local_req = {{}};
            struct svc_resp_{self.name} local_resp = {{}};

{from_uint16_vector_lambda("            ") if need_from_lambda else ''}
{init_request}
{to_uint16_vector_lambda("            ") if need_to_lambda else ''}
{init_response}

            svc_{self.name}(local_req, local_resp);

{parse_response}

            return 0;
        }}

        std::string local_owner,    //!< @brief local service owner
                    local_name;     //!< @brief local service name

    public:
        //! destruction, unregisters service
        virtual ~svc_base_{self.name}() {{
            try {{
                remove_svc_{self.name}();
            }} catch (const std::exception& e) {{
            }}
        }};

        //! svc_{self.name}
        /*!
         * @param[in]   req     Service request data.
         * @param[out]  resp    Service response data.
         */
        virtual void svc_{self.name}(
            const struct svc_req_{self.name}& req,
            struct svc_resp_{self.name}& resp) = 0;

        //! adding service to robotkernel service store
        /*!
         * @param[in]   owner   Owner of this service.
         * @param[in]   name    Unique name in 'owner' namespace.
         */
        void add_svc_{self.name}(std::string owner, std::string name) {{
            local_owner = owner;
            local_name = name;

{add_datatypes}

            ::robotkernel::add_service_definition(
                "{self.org_name}",
                {self.name}_service_definition);
            ::robotkernel::add_service(owner, name,
                "{self.org_name}",
                std::bind(&svc_base_{self.name}::svc_handler_{self.name},
                this, std::placeholders::_1, std::placeholders::_2));
        }}

        //! remove service from robotkernel service store
        void remove_svc_{self.name}(void) {{
            ::robotkernel::remove_service(local_owner, local_name);
        }}
}};

{namespaces_close}
'''

