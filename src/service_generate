import yaml
import os
import argparse

parser = argparse.ArgumentParser(description='Generate service definition header.')
parser.add_argument('--out', type=str, help='output header file name for service defintions')
parser.add_argument('--indir', type=str, help='input directory with svc_def files')
parser.add_argument('sd_files', metavar='svc_def', type=str, nargs='+',
                    help='yaml service definition files')
parser.add_argument('--name', type=str, help='base service definition name')
parser.add_argument('--add_namespace', type=str, help='additional base namespace')
parser.add_argument('--create-hdr-src-pair', dest='create_hdr_src_pair', action='store_true', help='Enable the feature')
parser.add_argument('--no-create-hdr-src-pair', dest='create_hdr_src_pair', action='store_false', help='Disable the feature')
parser.set_defaults(create_hdr_src_pair=False)

args = parser.parse_args()

print('service_generate: writing output to %s' % args.out)

outfd = open(args.out, 'w+')

import random
import string

def get_random_string(length):
    # choose from all uppercase letter
    letters = string.ascii_uppercase
    result_str = ''.join(random.choice(letters) for i in range(length))
    return result_str

def create_header(fd, name):
    hdr = f'''//! robotkernel service deinition header
/*!
 * author: generated by service_generator. DO NOT EDIT!
 */

#include <unistd.h>
#include <string>
#include <vector>
#include <robotkernel/service.h>
'''
    fd.write(hdr)
    if not args.create_hdr_src_pair:
        fd.write(f'''#include "robotkernel/robotkernel.h"
''')

    hdr = f'''#ifndef {name.upper()}_SERVICE_DEFINITIONS__H
#define {name.upper()}_SERVICE_DEFINITIONS__H

'''

    fd.write(hdr)

def create_footer(fd, name):
    ftr = f'''

#endif /* {name.upper()}_SERVICE_DEFINITIONS__H */

'''
    
    fd.write(ftr)

prefix = args.name
if prefix is None:
    prefix = get_random_string(32)

create_header(outfd, prefix)

add_namespace = args.add_namespace
if add_namespace is not None:
    outfd.write(f'namespace {add_namespace} {{\n') 

def service_datatype_to_ln(datatype):
    if datatype == "string":
        return "char*"

    return datatype        

def is_primitive(datatype):
    if datatype == "string":
        return False

    return True

def decode_datatype(datatype):
    if datatype == "string":
        return "std::string"

    if datatype.startswith('vector'):
        return "std::vector<" + decode_datatype(datatype[7:]) + ">"

    return datatype

global_defs = {}

def create_sd_string(sd, fd, fn_name, sd_name, indent=""):
    lines = []
    
    parts = fn_name.split('/')
    sd_name = parts[-1]

    global_defs[fn_name] = parts

    def create_namespace_opens(parts):
        tmp = []
        for d in parts[:-1]:
            tmp.append(f'namespace {d} {{')
        return '\n'.join(tmp)
    
    def create_namespace_closes(parts):
        tmp = []
        for d in parts[:-1]:
            tmp.append(f'}} // namespace {d}')
        return '\n'.join(tmp)

    def create_def(sd):
        tmp = []
        inputlines = yaml.dump(sd).split('\n')
        for line in inputlines:
            if line != "":
                line = line.replace('\\', '\\\\').replace('"', '\\"')
                tmp.append(f'{indent}"{line}\\n"')
        return '\n'.join(tmp)

    def create_entries(etype, sd, indent):
        tmp = []
        if etype in sd:
            for elem in sd[etype]:
                for entry in elem:
                    if entry.startswith('vector'):
                        real_entry = entry[7:]
                        tmp.append(f'{indent}std::vector<{decode_datatype(real_entry)}> {elem[entry]};')
                    else:
                        tmp.append(f'{indent}{decode_datatype(entry)} {elem[entry]};')
        return '\n'.join(tmp)

    lines.append(
        f'''
//=== SERVICE CODE GENERATED FOR {fn_name} ===

{create_namespace_opens(parts)}
 
//! service definition for {sd_name}
static const std::string {sd_name}_service_definition =
{create_def(sd)};

//! service request data structure for {sd_name}
struct svc_req_{sd_name} {{
{create_entries('request', sd, '    ')}
}};

//! service response data structure for {sd_name}
struct svc_resp_{sd_name} {{
{create_entries('response', sd, '    ')}
}};

//! base service class for {sd_name}
class svc_base_{sd_name} {{
    private: 
        //! internal service handler, this one is registered to robotkernel
        /*!
         * \param[in]   req     Service request argument list of type 'any'.
         * \param[out]  resp    Service response argument list of type 'any'.
         * \\return 0
         */
        int svc_handler_{sd_name}(
            const ::robotkernel::service_arglist_t &req, 
            ::robotkernel::service_arglist_t &resp) 
        {{''')
    
    lines.append(f'\t\t\tstruct svc_req_{sd_name} local_req;')
    lines.append(f'\t\t\tstruct svc_resp_{sd_name} local_resp;')

    if 'request' in sd:
        cnt = 0
        for elem in sd['request']:
            for entry in elem:
                lines.append(f'\t\t\tlocal_req.{elem[entry]} = ::robotkernel::rk_type_cast<{decode_datatype(entry)}>(req[{cnt}]);')
                cnt = cnt + 1
    lines.append(f'\n\t\t\tsvc_{sd_name}(local_req, local_resp);')

    if 'response' in sd:
        cnt = 0
        lines.append(f'\t\t\tresp.clear();')
        for elem in sd['response']:
            for entry in elem:
                lines.append(f'\t\t\tresp.push_back(local_resp.{elem[entry]});')
                cnt = cnt + 1
    
    lines.append(
        f'''
            return 0;
        }}

        std::string local_owner,    //!< \brief local service owner
                    local_name;     //!< \brief local service name

    public:
        //! destruction, unregisters service
        virtual ~svc_base_{sd_name}() {{ 
            try {{ 
                remove_svc_{sd_name}(); 
            }} catch (const std::exception& e) {{ 
            }} 
        }};

        //! svc_{sd_name}
        /*!
         * \param[in]   req     Service request data.
         * \param[out]  resp    Service response data.
         */
        virtual void svc_{sd_name}(
            const struct svc_req_{sd_name}& req, 
            struct svc_resp_{sd_name}& resp) = 0;

        //! adding service to robotkernel service store
        /*!
         * \param[in]   owner   Owner of this service.
         * \param[in]   name    Unique name in 'owner' namespace.
         */''')

    if args.create_hdr_src_pair:
        lines.append(f'''        void add_svc_{sd_name}(std::string owner, std::string name);

        //! remove service from robotkernel service store
        void remove_svc_{sd_name}(void);''')
    else:
        lines.append(f'''        void add_svc_{sd_name}(std::string owner, std::string name) {{
            local_owner = owner;
            local_name = name;

            ::robotkernel::add_service(owner, name, 
                {sd_name}_service_definition, 
                std::bind(&svc_base_{sd_name}::svc_handler_{sd_name}, 
                this, std::placeholders::_1, std::placeholders::_2));
        }}

        //! remove service from robotkernel service store
        void remove_svc_{sd_name}(void) {{
            ::robotkernel::remove_service(local_owner, local_name);
        }}''')
    lines.append(
        f'''
}};

{create_namespace_closes(parts)}
''')

    outsd = '\n'.join(lines)
    fd.write(f'{outsd}')

for fn in args.sd_files:
    sd = None
    sd_name = os.path.join(args.indir, fn)

    print("service_generate: processing %s" % (sd_name))
    
    with open(sd_name, 'r') as stream:
        try:
            sd = yaml.load(stream, Loader=yaml.FullLoader)
        except:
            sd = yaml.load(stream)
        
    create_sd_string(sd, outfd, fn, fn.replace('/', '_'))

lines = []

for k, v in global_defs.items():
    lines.append("const std::string " + "_".join(v) + "_service_definition = " + "::".join(v) + "_service_definition;")

outfd.write('\n')
outfd.write('\n'.join(lines))

if add_namespace is not None:
    outfd.write(f'\n\n}} // namespace {add_namespace}\n') 

create_footer(outfd, prefix)

