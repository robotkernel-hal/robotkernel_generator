#!/usr/bin/env python3

import yaml
import os
import argparse

parser = argparse.ArgumentParser(description='Generate service definition header.')
parser.add_argument('--out', type=str, help='output header file name for service defintions')
parser.add_argument('--indir', type=str, help='input directory with svc_def files')
parser.add_argument('sd_files', metavar='svc_def', type=str, nargs='+',
                    help='yaml service definition files')

args = parser.parse_args()

print('service_generate: writing output to %s' % args.out)

outfd = open(args.out, 'w+')

def create_header(fd):
    hdr = '''//! robotkernel service deinition header
/*!
 * author: generated by service_generator
 */
/*

 * This file is part of robotkernel.
 *
 * robotkernel is free software: you can redistribute it and/or modify
 * it under the terms of the GNU General Public License as published by
 * the Free Software Foundation, either version 3 of the License, or
 * (at your option) any later version.
 *
 * robotkernel is distributed in the hope that it will be useful,
 * but WITHOUT ANY WARRANTY; without even the implied warranty of
 * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
 * GNU General Public License for more details.
 *
 * You should have received a copy of the GNU General Public License
 * along with robotkernel.  If not, see <http://www.gnu.org/licenses/>.
 */

#include <unistd.h>
#include <string>
#include <robotkernel/service.h>

#ifndef SERVICE_DEFINITIONS__H
#define SERVICE_DEFINITIONS__H

'''

    fd.write(hdr)

def create_footer(fd):
    ftr = '''

#endif /* SERVICE_DEFINITIONS__H */

'''
    
    fd.write(ftr)

create_header(outfd)

def service_datatype_to_ln(datatype):
    if datatype == "string":
        return "char*"

    return datatype        

def is_primitive(datatype):
    if datatype == "string":
        return False

    return True

def create_sd_string(sd, fd, sd_name, indent=""):
    lines = []
    lines.append(f'{indent}static const std::string {sd_name}_service_definition = ')
    for line in yaml.dump(sd).split('\n'):
        if line != "":
            lines.append(f'{indent}"{line}\\n"')

    outsd = '\n'.join(lines)
    fd.write(f'{outsd};\n\n')

for fn in args.sd_files:
    sd = None
    sd_name = os.path.join(args.indir, fn)

    print("service_generate: processing %s" % (sd_name))
    
    with open(sd_name, 'r') as stream:
        sd = yaml.load(stream, Loader=yaml.SafeLoader)
        
    create_sd_string(sd, outfd, fn.replace('/', '_'))

create_footer(outfd)

