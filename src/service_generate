def create_footer(fd, name):
    ftr = f'''

#endif /* {name.upper()}_SERVICE_DEFINITIONS__H */

'''

    fd.write(ftr)

def is_primitive(datatype):
    if datatype == "string":
        return False

    return True

def decode_datatype(elem, with_name=False, yaml_use=False):
    dtype = elem.type if not yaml_use else elem.yaml_type

    if not is_builtin(dtype):
        real_dtype = types[dtype]
        dtype = "::".join(real_dtype.namespaces + [real_dtype.real_name])

    if dtype == "string":
        dtype = "std::string"

    if elem.array:
        if elem.size > 0:
            dtype = f'{dtype} {elem.name}[{elem.size}]' if with_name else f'{dtype}[{elem.size}]'
        else:
            dtype = f'std::vector<{dtype}> {elem.name}' if with_name else f'std::vector<{dtype}>'
    else:
        dtype = f'{dtype} {elem.name}' if with_name else dtype

    return dtype

def decode_default(datatype, default):
    if datatype == "string":
        return f"\"{default}\""
    if datatype == "bool":
        return "true" if default else "false"

    return default

for fn in args.sd_files:
    sd = None
    sd_name = os.path.join(args.indir, fn)

    print("service_generate: processing %s" % (sd_name))

    with open(sd_name, 'r') as stream:
        try:
            sd = yaml.load(stream, Loader=yaml.FullLoader)
        except:
            sd = yaml.load(stream)

    #print(yaml.dump(sd, default_flow_style=False, sort_keys=False))
    if "datatypes" in sd:
        for n, e in sd["datatypes"].items():
            tp = dtype(n, e)
            types[tp.name] = tp

    if "services" in sd:
        for n, e in sd["services"].items():
            tp = svc_base(n, e)
            bases[tp.name] = tp

    if "pds" in sd:
        for n, e in sd["pds"].items():
            tp = pd_base(n, e)
            pds[tp.name] = tp


outfd = open(args.out, 'w+')

prefix = args.name
if prefix is None:
    prefix = get_random_string(32)

create_header(outfd, prefix)

add_namespace = args.add_namespace
if add_namespace is not None:
    outfd.write(f'namespace {add_namespace} {{\n')

for name, dtype in types.items():
    outfd.write(dtype.create_struct())
    outfd.write(dtype.create_yaml_coverters())

for name, svc in bases.items():
    outfd.write(svc.create_class())

for name, pd in pds.items():
    outfd.write(pd.create_class())

if add_namespace is not None:
    outfd.write(f'\n\n}} // namespace {add_namespace}\n')

create_footer(outfd, prefix)

